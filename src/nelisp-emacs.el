  "Stable package APIs exposed through explicit lazy companion features.
These symbols are part of the reusable package contract, but they are not
loaded by requiring `nelisp-emacs'.  Consumers must require the entry's
`:feature' before relying on the listed symbols.")

(defun nelisp-emacs--copy-package-plist (plist)
  "Return a copy of package PLIST with copied list values."
  (let ((copy (copy-sequence plist)))
    (dolist (key '(:features :lazy-features))
      (let ((value (plist-get copy key)))
        (plist-put copy key (and value (copy-sequence value)))))
    copy))

(defun nelisp-emacs--copy-stable-api-entry (entry)
  "Return a copy of stable API ENTRY."
  (let ((copy (copy-sequence (cdr entry))))
    (plist-put copy :symbols
               (mapcar #'copy-sequence (plist-get copy :symbols)))
    (cons (car entry) copy)))

(defun nelisp-emacs-library-package-manifest ()
  "Return a copy of `nelisp-emacs-library-packages'."
  (mapcar
   (lambda (entry)
     (cons (car entry)
           (nelisp-emacs--copy-package-plist (cdr entry))))
   nelisp-emacs-library-packages))

(defun nelisp-emacs-library-stable-api-manifest ()
  "Return a copy of the stable package API manifest."
  (mapcar #'nelisp-emacs--copy-stable-api-entry
          nelisp-emacs-library-stable-package-api))

(defun nelisp-emacs-library-stable-api-symbols (&optional package)
  "Return stable package API symbols.
When PACKAGE is non-nil, return only symbols for that reusable package
group.  Without PACKAGE, return all stable package API symbols."
  (let ((entries (if package
                     (let ((entry
                            (assq package
                                  nelisp-emacs-library-stable-package-api)))
                       (and entry (list entry)))
                   nelisp-emacs-library-stable-package-api))
        symbols)
    (dolist (entry entries)
      (dolist (spec (plist-get (cdr entry) :symbols))
        (push (nth 1 spec) symbols)))
    (nreverse symbols)))

(defun nelisp-emacs-library-stable-api-entry (symbol)
  "Return stable package API metadata for SYMBOL, or nil.
The returned plist contains `:package', `:owner', `:package-id', and
`:kind'."
  (catch 'found
    (dolist (entry nelisp-emacs-library-stable-package-api)
      (let ((package (car entry))
            (plist (cdr entry)))
        (dolist (spec (plist-get plist :symbols))
          (when (eq (nth 1 spec) symbol)
            (throw 'found
                   (list :package package
                         :owner (plist-get plist :owner)
                         :package-id (plist-get plist :package-id)
                         :kind (nth 0 spec)))))))
    nil))

(defun nelisp-emacs-library-stable-lazy-api-manifest ()
  "Return a copy of the stable lazy package API manifest."
  (mapcar #'nelisp-emacs--copy-stable-api-entry
          nelisp-emacs-library-stable-lazy-package-api))

(defun nelisp-emacs-library-stable-lazy-api-symbols (&optional package)
  "Return stable lazy package API symbols.
When PACKAGE is non-nil, return only symbols for that reusable package
group.  Without PACKAGE, return all stable lazy package API symbols."
  (let (entries symbols)
    (if package
        (progn
          (dolist (entry nelisp-emacs-library-stable-lazy-package-api)
            (when (eq (car entry) package)
              (push entry entries)))
          (setq entries (nreverse entries)))
      (setq entries nelisp-emacs-library-stable-lazy-package-api))
    (dolist (entry entries)
      (dolist (spec (plist-get (cdr entry) :symbols))
        (push (nth 1 spec) symbols)))
    (nreverse symbols)))

(defun nelisp-emacs-library-stable-lazy-api-entry (symbol)
  "Return stable lazy package API metadata for SYMBOL, or nil.
The returned plist contains `:package', `:owner', `:package-id',
`:feature', and `:kind'.  Consumers must require `:feature' before
relying on SYMBOL."
  (catch 'found
    (dolist (entry nelisp-emacs-library-stable-lazy-package-api)
      (let ((package (car entry))
            (plist (cdr entry)))
        (dolist (spec (plist-get plist :symbols))
          (when (eq (nth 1 spec) symbol)
            (throw 'found
                   (list :package package
                         :owner (plist-get plist :owner)
                         :package-id (plist-get plist :package-id)
                         :feature (plist-get plist :feature)
                         :kind (nth 0 spec)))))))
    nil))

(defun nelisp-emacs-library-package-names ()
  "Return reusable package group names exposed by `nelisp-emacs'."
  (mapcar #'car nelisp-emacs-library-packages))

(defun nelisp-emacs-library-package (name)
  "Return a copy of reusable package group NAME's plist, or nil.
The returned plist contains `:owner', `:feature', `:features', and
`:lazy-features'."
  (let ((entry (assq name nelisp-emacs-library-packages)))
    (when entry
      (nelisp-emacs--copy-package-plist (cdr entry)))))

(defun nelisp-emacs-library-package-features (name)
  "Return a copy of reusable package group NAME's member features."
  (let ((package (nelisp-emacs-library-package name)))
    (and package (plist-get package :features))))

(defun nelisp-emacs-library-package-lazy-features (name)
  "Return a copy of reusable package group NAME's lazy companion features."
  (let ((package (nelisp-emacs-library-package name)))
    (and package (plist-get package :lazy-features))))

