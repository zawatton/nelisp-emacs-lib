;;; Commentary:

;; Public library entry point for consumers that want the reusable
;; nelisp-emacs C-core replacement surface without loading the
;; application/bootstrap policy in `emacs-init'.  Optional app features
;; such as TUI realization and editor-heavy lazy features remain behind
;; the `emacs-init-load-*' functions.

;;; Code:

(defconst nelisp-emacs-library-contract-version 1
  "Version of the external `nelisp-emacs' library consumer contract.")

(defconst nelisp-emacs-library-features
  '(emacs-foundation
    emacs-text-core
    emacs-buffer-core
    emacs-editing
    emacs-io
    emacs-special-buffers
    emacs-core
    emacs-textmodes-stub)
  "Reusable feature groups loaded by the `nelisp-emacs' facade.
This manifest is intentionally limited to library-owned surfaces.
Application bootstrap, concrete TUI/GUI frontends, and editor-heavy lazy
features remain behind `emacs-init' and its explicit loader functions.")

(dolist (feature nelisp-emacs-library-features)
  (require feature))

(defconst nelisp-emacs-library-packages
  `((foundation
     :owner FND
     :feature emacs-foundation
     :features ,emacs-foundation-features
     :lazy-features nil)
    (text-core
     :owner TXT
     :feature emacs-text-core
     :features ,emacs-text-core-features
     :lazy-features (nelisp-coding-jis-tables))
    (buffer-core
     :owner BUF
     :feature emacs-buffer-core
     :features ,emacs-buffer-core-features
     :lazy-features (emacs-bookmark-ui
                     emacs-buffer-ui
                     emacs-isearch
                     emacs-replace))
    (editing
     :owner BUF
     :feature emacs-editing
     :features ,emacs-editing-features
     :lazy-features nil)
    (io
     :owner IO
     :feature emacs-io
     :features ,emacs-io-features
     :lazy-features (emacs-dump
                     image-loader
                     nemacs-loaddefs
                     emacs-dired-min
                     files-standalone-buffer
                     emacs-shell-command
                     emacs-project))
    (special-buffers
     :owner BUF
     :feature emacs-special-buffers
     :features (emacs-special-buffers)
     :lazy-features nil)
    (core
     :owner CORE
     :feature emacs-core
     :features ,emacs-core-features
     :lazy-features (emacs-elisp-eval
                     emacs-elisp-mode
                     emacs-font-lock
                     emacs-ielm
                     lisp-mode
                     emacs-redisplay-core
                     emacs-syntax-table
                     emacs-tui-backend
                     emacs-tui-event
                     emacs-tui-terminfo))
    (textmodes-stub
     :owner FEAT
     :feature emacs-textmodes-stub
     :features (emacs-textmodes-stub)
     :lazy-features nil))
  "Reusable package groups exposed by the `nelisp-emacs' facade.
Each entry is `(NAME :owner OWNER :feature FEATURE :features FEATURES
:lazy-features LAZY-FEATURES)'.  OWNER matches the primary Doc 18
  ownership group.  FEATURE is the facade feature for that package group.
FEATURES is the eager load membership for that group.  LAZY-FEATURES are
package-owned companion features that stay out of facade eager loads.")

