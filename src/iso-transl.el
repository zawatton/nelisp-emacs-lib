  "Language-specific shorter translation lists for `C-x 8'.")

(defvar iso-transl-ctl-x-8-map nil
  "Keymap for the `C-x 8' ISO translation prefix.")

(defun iso-transl--ensure-keymaps ()
  "Ensure the keymaps used by this lightweight facade exist."
  (unless iso-transl-ctl-x-8-map
    (setq iso-transl-ctl-x-8-map (make-sparse-keymap))
    (fset 'iso-transl-ctl-x-8-map iso-transl-ctl-x-8-map))
  (unless key-translation-map
    (setq key-translation-map (make-sparse-keymap)))
  (define-key key-translation-map "\C-x8" iso-transl-ctl-x-8-map))

(defun iso-transl--define-isearch-dead-key (key)
  "Clear KEY in `isearch-mode-map' when that map is available."
  (when (and isearch-mode-map (keymapp isearch-mode-map))
    (define-key isearch-mode-map key nil)))

(defun iso-transl--define-alt-and-dead-keys (key translated-vec)
  "Install Alt and dead-key translations for KEY to TRANSLATED-VEC."
  (let ((inchar (aref key 0))
        (vec (vconcat key)))
    (aset vec 0 (logior (aref vec 0) iso-transl--alt-modifier-mask))
    (define-key key-translation-map vec translated-vec)
    (iso-transl--define-isearch-dead-key (vector (aref vec 0)))
    (dolist (entry iso-transl-dead-key-alist)
      (when (eq (car entry) inchar)
        (let ((deadvec (copy-sequence vec))
              (deadkey (cdr entry)))
          (aset deadvec 0 deadkey)
          (define-key key-translation-map deadvec translated-vec)
          (iso-transl--define-isearch-dead-key (vector deadkey)))))))

(defun iso-transl-define-keys (alist)
  "Install ISO translations from ALIST.
Each entry is (KEY . TRANSLATION), matching GNU Emacs'
`iso-transl-char-map' shape."
  (iso-transl--ensure-keymaps)
  (dolist (entry alist)
    (let ((key (car entry))
          (translated-vec (cdr entry)))
      (define-key iso-transl-ctl-x-8-map key translated-vec)
      (iso-transl--define-alt-and-dead-keys key translated-vec))))

(defun iso-transl-set-language (lang)
  "Set shorter key bindings for characters relevant for LANG."
  (interactive
   (list (let ((completion-ignore-case t))
           (completing-read "Set which language? "
                            iso-transl-language-alist nil t))))
  (let ((entry (assoc lang iso-transl-language-alist)))
    (unless entry
      (error "Unknown iso-transl language: %s" lang))
    (iso-transl-define-keys (cdr entry))))

(iso-transl-define-keys iso-transl-char-map)

(provide 'iso-transl)

