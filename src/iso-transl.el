(defvar iso-transl-dead-key-alist
  '((?' . mute-acute)
    (?` . mute-grave)
    (?\" . mute-diaeresis)
    (?^ . mute-asciicircum)
    (?~ . mute-asciitilde)
    (?' . dead-acute)
    (?` . dead-grave)
    (?\" . dead-diaeresis)
    (?^ . dead-asciicircum)
    (?~ . dead-asciitilde)
    (?^ . dead-circum)
    (?^ . dead-circumflex)
    (?~ . dead-tilde))
  "Mapping of ASCII accent characters to dead-key symbols.")

