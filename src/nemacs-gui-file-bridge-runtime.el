                nil)
              (setq args (cdr args))
              (if args
                  (if (stringp (car args))
                      (setq emacs-minibuffer-gui-initial-input (car args))
                    nil)
                nil))
          nil)
        (setq emacs-minibuffer-gui-require-match nil)
        (emacs-minibuffer-gui-begin-read)
        (emacs-minibuffer-gui--set-initial-input)))

