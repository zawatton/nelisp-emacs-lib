        (setq emacs-minibuffer-gui-initial-input "")
        (setq emacs-minibuffer-gui-collection nil)
        (setq emacs-minibuffer-gui-completion-table "")
        (setq emacs-minibuffer-gui-require-match nil)
        (if args
