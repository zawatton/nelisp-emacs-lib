              (end files--point))
          (setq files--highlight-symbol "")
          (if (if (> i 0)
                  (progn
                    (setq files--char-code
                          (aref files--buffer-string (- i 1)))
                    (files--word-char-p))
                nil)
              (progn
                (while (if (> i 0)
                           (progn
                             (setq files--char-code
                                   (aref files--buffer-string (- i 1)))
                             (files--word-char-p))
                         nil)
                  (setq i (- i 1)))
                (setq start i))
            (progn
              (while (if (< i n)
                         (progn
                           (setq files--char-code
                                 (aref files--buffer-string i))
                           (not (files--word-char-p)))
                       nil)
                (setq i (+ i 1)))
              (setq start i)))
          (setq i start)
          (while (if (< i n)
                     (progn
                       (setq files--char-code (aref files--buffer-string i))
                       (files--word-char-p))
                   nil)
            (setq i (+ i 1)))
          (setq end i)
          (if (< start end)
              (setq files--highlight-symbol
                    (substring files--buffer-string start end))
            nil)
          files--highlight-symbol)))

