(fset 'emacs-minibuffer-gui-complete
      (lambda ()
        (files--refresh-minibuffer-candidates)
        (let ((candidates files--minibuffer-candidates)
              (index 0))
          (while (if (< index (length candidates))
                     (not (= (aref candidates index) 10))
