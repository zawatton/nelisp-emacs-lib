(fset 'beginning-of-line
      (lambda ()
        (files--clamp-point)
        (let ((i files--point)
              (done nil))
          (while (if (> i 0) (not done) nil)
            (if (= (aref files--buffer-string (- i 1)) 10)
                (setq done t)
              (setq i (- i 1))))
          (setq files--point i)
          files--point)))

