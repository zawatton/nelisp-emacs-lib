                        (progn
                          (setq out
                                (concat out
                                        (substring files--buffer-string match-end (+ match-end 1))))
                          (setq cursor (+ match-end 1))
                          (setq search-from (+ match-end 1)))
                      (progn
                        (setq cursor match-end)
                        (setq search-from (+ n 1))))
                  (progn
                    (setq cursor match-end)
                    (setq search-from match-end))))
