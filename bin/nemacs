#!/usr/bin/env bash
# nemacs — nelisp-emacs Layer 2 launcher
#
# Wraps the host Emacs (default driver) or `nelisp` (experimental driver)
# so that users can spawn nemacs the same way they would spawn Emacs.
# Usage shape mirrors `emacs --batch ...`:
#
#   nemacs                          interactive TUI runner
#   nemacs --batch                  batch entry (= boots, runs --eval/-l, exits)
#   nemacs --batch -l FILE          batch + load FILE
#   nemacs --batch -L DIR           batch + prepend DIR to load-path
#   nemacs --batch -f FUNCTION      batch + call FUNCTION after load/eval
#   nemacs --batch --runtime-image FILE load a NeLisp .nlri runtime image first
#   nemacs --runtime-image auto       choose build/*.nlri by batch/interactive mode
#   nemacs --batch --load-image FILE legacy: restore Lisp-visible .nli state
#   nemacs --batch --eval FORM      batch + eval FORM
#   nemacs --batch -l a -l b --eval '(...)'
#   nemacs -q                       skip user init.el/early-init.el (like Emacs -q)
#   nemacs --no-init-file           same as -q
#   nemacs -Q                       -q + suppress the startup splash (like Emacs -Q)
#   nemacs --quick                  same as -Q
#   nemacs --no-splash              suppress the startup splash screen only
#   nemacs --no-site-file           accepted for Emacs CLI compatibility (no-op)
#   nemacs --driver=nelisp ...      use NeLisp as driver
#   nemacs --driver=host ...        force host emacs driver (= default)
#   nemacs --print-paths            dump the resolved load-path / vendor root
#   nemacs --doctor                 run host/NeLisp driver readiness checks
#   nemacs --version                print nemacs version + driver
#   nemacs --help                   this message
#
# Environment overrides:
#   NEMACS_HOME      directory containing src/ (default: this script's parent)
#   NELISP_HOME      nelisp checkout (default: vendor/nelisp, then ../nelisp)
#   NEMACS_DRIVER    `host' (default) or `nelisp'
#   NEMACS_EMACS     emacs binary path (default: emacs)
#   NEMACS_NELISP    nelisp binary path (default: standalone-reader)
#   NEMACS_NELISP_STACK stack limit for the nelisp driver (default: unlimited)
#   NEMACS_BOOTSTRAP_BUNDLE optional generated NeLisp preload bundle
#                    (default: $NEMACS_HOME/build/nemacs-bootstrap.el)
#   NEMACS_BOOTSTRAP_REPL optional generated NeLisp REPL bootstrap input
#                    (default: $NEMACS_HOME/build/nemacs-bootstrap.repl)
#   NEMACS_RUNTIME_IMAGE optional NeLisp .nlri runtime image for --driver=nelisp
#                    (set to `auto' to choose build/*.nlri by mode)

set -euo pipefail

SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)"
NEMACS_HOME="${NEMACS_HOME:-$(cd "$SCRIPT_PATH/.." && pwd)}"

# NeLisp provides a pure-Elisp standalone reader at target/nelisp.
# Prefer this repo's vendored checkout,
# then the common sibling checkout used during joint development, then
# the legacy ~/Notes/dev path.
DEFAULT_VENDOR_NELISP="$NEMACS_HOME/vendor/nelisp"
DEFAULT_SIBLING_NELISP="$(cd "$NEMACS_HOME/.." && pwd)/nelisp"
DEFAULT_LEGACY_NELISP="$HOME/Notes/dev/nelisp"
nelisp_default_bin() {
  local root="$1"
  if [[ -x "$root/target/nelisp" ]]; then
    printf '%s\n' "$root/target/nelisp"
    return 0
  fi
  if [[ -x "$root/target/nelisp-standalone-reader" ]]; then
    printf '%s\n' "$root/target/nelisp-standalone-reader"
  fi
}
if [[ -z "${NELISP_HOME:-}" ]]; then
  if [[ -n "$(nelisp_default_bin "$DEFAULT_VENDOR_NELISP")" ]]; then
    NELISP_HOME="$DEFAULT_VENDOR_NELISP"
  elif [[ -n "$(nelisp_default_bin "$DEFAULT_SIBLING_NELISP")" ]]; then
    NELISP_HOME="$DEFAULT_SIBLING_NELISP"
  elif [[ -n "$(nelisp_default_bin "$DEFAULT_LEGACY_NELISP")" ]]; then
    NELISP_HOME="$DEFAULT_LEGACY_NELISP"
  else
    NELISP_HOME="$DEFAULT_VENDOR_NELISP"
  fi
fi
NEMACS_DRIVER="${NEMACS_DRIVER:-host}"
NEMACS_EMACS="${NEMACS_EMACS:-emacs}"
NEMACS_NELISP="${NEMACS_NELISP:-$(nelisp_default_bin "$NELISP_HOME")}"
NEMACS_NELISP="${NEMACS_NELISP:-$NELISP_HOME/target/nelisp}"
NEMACS_NELISP_STACK="${NEMACS_NELISP_STACK:-unlimited}"
# Address-space cap (ulimit -v, KiB) for the nelisp driver.  The standalone
# reader only reclaims transient allocations at top-level form boundaries, so a
# long-lived single form (e.g. the `nemacs-main--event-loop' while form) leaks
# ~8 KiB/iteration and can grow unbounded (Doc 152 §11.33/§11.34).  Capping the
# address space makes a runaway exit cleanly (rc=88 on mmap failure) at the
# limit instead of exhausting host RAM and freezing the machine.  8 GiB is far
# above any legitimate editor session (baseline ~60 MiB) yet well under host RAM.
# Set NEMACS_NELISP_MEMORY=unlimited to disable.
NEMACS_NELISP_MEMORY="${NEMACS_NELISP_MEMORY:-8388608}"
NEMACS_BOOTSTRAP_BUNDLE="${NEMACS_BOOTSTRAP_BUNDLE:-$NEMACS_HOME/build/nemacs-bootstrap.el}"
NEMACS_BOOTSTRAP_REPL="${NEMACS_BOOTSTRAP_REPL:-$NEMACS_HOME/build/nemacs-bootstrap.repl}"
NEMACS_RUNTIME_IMAGE="${NEMACS_RUNTIME_IMAGE:-}"
NEMACS_BATCH_RUNTIME_IMAGE="${NEMACS_BATCH_RUNTIME_IMAGE:-$NEMACS_HOME/build/nemacs-runtime.nlri}"
NEMACS_INTERACTIVE_RUNTIME_IMAGE="${NEMACS_INTERACTIVE_RUNTIME_IMAGE:-$NEMACS_HOME/build/nemacs-interactive-runtime.nlri}"
NEMACS_VENDOR_CORE_RUNTIME_IMAGE="${NEMACS_VENDOR_CORE_RUNTIME_IMAGE:-$NEMACS_HOME/build/nemacs-vendor-core-runtime.nlri}"
if [[ "$NEMACS_BOOTSTRAP_BUNDLE" == "none" ]]; then
  NEMACS_BOOTSTRAP_BUNDLE=""
fi
NEMACS_VERSION="0.1.0-mvp"

usage() {
  sed -n '2,36p' "$0"
}

print_paths() {
  cat <<EOF
nemacs paths:
  NEMACS_HOME      = $NEMACS_HOME
  NELISP_HOME      = $NELISP_HOME
  NEMACS_DRIVER    = $NEMACS_DRIVER
  NEMACS_EMACS     = $NEMACS_EMACS
  NEMACS_NELISP    = $NEMACS_NELISP
  NEMACS_NELISP_STACK = $NEMACS_NELISP_STACK
  NEMACS_NELISP_MEMORY = $NEMACS_NELISP_MEMORY
  NEMACS_BOOTSTRAP_BUNDLE = ${NEMACS_BOOTSTRAP_BUNDLE:-<disabled>}
  NEMACS_BOOTSTRAP_REPL = ${NEMACS_BOOTSTRAP_REPL:-<disabled>}
  NEMACS_RUNTIME_IMAGE = ${NEMACS_RUNTIME_IMAGE:-<disabled>}
  NEMACS_BATCH_RUNTIME_IMAGE = $NEMACS_BATCH_RUNTIME_IMAGE
  NEMACS_INTERACTIVE_RUNTIME_IMAGE = $NEMACS_INTERACTIVE_RUNTIME_IMAGE
  NEMACS_VENDOR_CORE_RUNTIME_IMAGE = $NEMACS_VENDOR_CORE_RUNTIME_IMAGE
  src/             = $NEMACS_HOME/src
  vendor/          = $NEMACS_HOME/vendor
EOF
}

doctor_block() {
  local text="$1"
  if [[ -n "$text" ]]; then
    printf '%s\n' "$text" | sed 's/^/    /'
  fi
}

nelisp_driver_kind() {
  case "$(basename "$NEMACS_NELISP")" in
    nelisp|nelisp-standalone-reader) printf '%s\n' "standalone-reader" ;;
    *) printf '%s\n' "cli" ;;
  esac
}

nelisp_standalone_eval_value() {
  local form="$1"
  local expected="$2"
  local rc out
  set +e
  out=$("$NEMACS_NELISP" --eval "$form" 2>&1)
  rc=$?
  set -e
  local trimmed="${out//[$' \t\r\n']/}"
  # The pure-Elisp standalone reader signals an `--eval' result either by
  # printing the value and exiting 0, or by exiting *with* the value as the
  # process exit code.  Accept both so the readiness probe stays convention-
  # agnostic across reader builds.
  if [[ "$rc" == 0 && "$trimmed" == "$expected" ]]; then
    printf 'exit=%s value=%s\n' "$rc" "$out"
    return 0
  fi
  if [[ "$rc" == "$expected" ]]; then
    printf 'exit=%s value=%s\n' "$rc" "$rc"
    return 0
  fi
  printf 'exit=%s expected-value=%s\n' "$rc" "$expected"
  if [[ -n "$out" ]]; then
    printf '%s\n' "$out"
  fi
  return 1
}

run_doctor() {
  local failures=0
  local out
  local nelisp_kind

  echo "nemacs doctor:"
  echo "  NEMACS_HOME=$NEMACS_HOME"
  echo "  NELISP_HOME=$NELISP_HOME"
  echo "  NEMACS_EMACS=$NEMACS_EMACS"
  echo "  NEMACS_NELISP=$NEMACS_NELISP"

  if out=$("$NEMACS_EMACS" -Q --batch \
           --eval '(setq native-comp-enable-subr-trampolines nil comp-enable-subr-trampolines nil)' \
           --eval '(princ "HOST=ok\n")' 2>&1); then
    echo "  host-batch: ok"
  else
    echo "  host-batch: fail"
    doctor_block "$out"
    failures=$((failures + 1))
  fi

  if out=$(NEMACS_HOME="$NEMACS_HOME" \
           NEMACS_EMACS="$NEMACS_EMACS" \
           NEMACS_DRIVER=host \
           "$SCRIPT_PATH/nemacs" --driver=host --batch --no-banner \
           --eval '(princ "NEMACS_HOST=ok\n")' 2>&1); then
    echo "  nemacs-host-batch: ok"
    doctor_block "$out"
  else
    echo "  nemacs-host-batch: fail"
    doctor_block "$out"
    failures=$((failures + 1))
  fi

  if [[ ! -x "$NEMACS_NELISP" ]]; then
    echo "  nelisp-binary: fail"
    echo "    not executable: $NEMACS_NELISP"
    failures=$((failures + 1))
  else
    echo "  nelisp-binary: ok"
    nelisp_kind="$(nelisp_driver_kind)"
    echo "  nelisp-driver-kind: $nelisp_kind"

    ulimit -s "$NEMACS_NELISP_STACK" 2>/dev/null || true
    [[ "$NEMACS_NELISP_MEMORY" == "unlimited" ]] || ulimit -v "$NEMACS_NELISP_MEMORY" 2>/dev/null || true
    if [[ "$nelisp_kind" == "standalone-reader" ]]; then
      echo "  nelisp-version: skip"
      echo "    standalone-reader has no --version command"

      if out=$(nelisp_standalone_eval_value 42 42); then
        echo "  nelisp-literal-eval: ok"
        doctor_block "$out"
      else
        echo "  nelisp-literal-eval: fail"
        doctor_block "$out"
        failures=$((failures + 1))
      fi

      if out=$(nelisp_standalone_eval_value '(+ 40 2)' 42); then
        echo "  nelisp-list-eval: ok"
        doctor_block "$out"
      else
        echo "  nelisp-list-eval: fail"
        doctor_block "$out"
        failures=$((failures + 1))
      fi
    else
      if out=$("$NEMACS_NELISP" --version 2>&1); then
        echo "  nelisp-version: ok"
        doctor_block "$out"
      else
        echo "  nelisp-version: fail"
        doctor_block "$out"
        failures=$((failures + 1))
      fi

      if out=$("$NEMACS_NELISP" --eval 42 2>&1); then
        echo "  nelisp-literal-eval: ok"
        doctor_block "$out"
      else
        echo "  nelisp-literal-eval: fail"
        doctor_block "$out"
        failures=$((failures + 1))
      fi

      if out=$("$NEMACS_NELISP" --eval '(identity 42)' 2>&1); then
        echo "  nelisp-list-eval: ok"
        doctor_block "$out"
      else
        echo "  nelisp-list-eval: fail"
        doctor_block "$out"
        failures=$((failures + 1))
      fi
    fi
  fi

  if (( failures == 0 )); then
    echo "  summary: ok"
  else
    echo "  summary: fail ($failures)"
  fi
  return "$failures"
}

# --- parse args ----------------------------------------------------

BATCH=0
NO_BANNER=0
NO_INIT=0
NO_SPLASH=0
DOCTOR=0
LOAD_FILES=()
LOAD_PATHS=()
IMAGE_FILES=()
EVAL_FORMS=()
FUNCALLS=()
EXTRA_ARGS=()
HOST_EARLY_ARGS=()

while (( $# > 0 )); do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    --version)
      echo "nemacs $NEMACS_VERSION (driver=$NEMACS_DRIVER)"
      exit 0 ;;
    --print-paths) print_paths; exit 0 ;;
    --doctor) DOCTOR=1; shift ;;
    -q|--no-init-file) NO_INIT=1; shift ;;
    -Q|--quick) NO_INIT=1; NO_SPLASH=1; shift ;;
    --no-splash) NO_SPLASH=1; shift ;;
    --no-site-file) shift ;;
    -nw|--no-window-system)
      HOST_EARLY_ARGS+=("$1"); shift ;;
    --batch) BATCH=1; shift ;;
    --no-banner) NO_BANNER=1; shift ;;
    --driver=*) NEMACS_DRIVER="${1#--driver=}"; shift ;;
    --driver) NEMACS_DRIVER="$2"; shift 2 ;;
    -L|--directory)
      [[ -n "${2-}" ]] || { echo "nemacs: $1 requires an argument" >&2; exit 2; }
      LOAD_PATHS+=("$2"); shift 2 ;;
    -L*) LOAD_PATHS+=("${1#-L}"); shift ;;
    --directory=*) LOAD_PATHS+=("${1#--directory=}"); shift ;;
    -l)
      [[ -n "${2-}" ]] || { echo "nemacs: -l requires an argument" >&2; exit 2; }
      LOAD_FILES+=("$2"); shift 2 ;;
    --load)
      [[ -n "${2-}" ]] || { echo "nemacs: --load requires an argument" >&2; exit 2; }
      LOAD_FILES+=("$2"); shift 2 ;;
    --load=*) LOAD_FILES+=("${1#--load=}"); shift ;;
    --load-image|--image)
      [[ -n "${2-}" ]] || { echo "nemacs: $1 requires an argument" >&2; exit 2; }
      IMAGE_FILES+=("$2"); shift 2 ;;
    --load-image=*|--image=*) IMAGE_FILES+=("${1#*=}"); shift ;;
    --runtime-image)
      [[ -n "${2-}" ]] || { echo "nemacs: --runtime-image requires an argument" >&2; exit 2; }
      NEMACS_RUNTIME_IMAGE="$2"; shift 2 ;;
    --runtime-image=*) NEMACS_RUNTIME_IMAGE="${1#*=}"; shift ;;
    --eval)
      [[ -n "${2-}" ]] || { echo "nemacs: --eval requires an argument" >&2; exit 2; }
      EVAL_FORMS+=("$2"); shift 2 ;;
    --eval=*) EVAL_FORMS+=("${1#--eval=}"); shift ;;
    -f|--funcall)
      [[ -n "${2-}" ]] || { echo "nemacs: $1 requires an argument" >&2; exit 2; }
      FUNCALLS+=("$2"); shift 2 ;;
    --funcall=*) FUNCALLS+=("${1#--funcall=}"); shift ;;
    --) shift; while (($#>0)); do EXTRA_ARGS+=("$1"); shift; done ;;
    *) EXTRA_ARGS+=("$1"); shift ;;
  esac
done

if (( DOCTOR )); then
  run_doctor
  exit $?
fi

# --- macro-less driver pre-pass: wrap user init ahead of time (Phase 3) --
#
# Loader reconcile Phase 3.  The nelisp/standalone driver's reader cannot
# reliably macro-expand every user init construct (Doc reconcile plan
# §1), so ahead of dispatch we run the same host-side `nemacs-wrap-init'
# generator the GUI launcher uses (scripts/nemacs-wrap-init.el), writing
# its output under `nemacs-resolve-user-emacs-directory' (src/nemacs-
# loadup.el) -- the single source every driver now defers to -- so
# `nemacs-loadup''s Phase 2 consumer (`nemacs--load-user-init-via-
# transport') picks it up automatically once `nemacs-init' runs below.
#
# Skipped entirely for the host driver (host Emacs macro-expands every
# construct itself, Phase 1's raw `load' is always sufficient there) and
# under -q/-Q (`NO_INIT'; the loadup init gate skips loading either way --
# double closure, nothing to wrap).  Host Emacs unavailable, or the
# generator failing, is a silent degrade to the Phase 1 raw-load lane
# (unchanged pre-Phase-3 behavior).
if [[ "$NEMACS_DRIVER" == "nelisp" && "$NO_INIT" != 1 ]] \
   && command -v "$NEMACS_EMACS" >/dev/null 2>&1; then
  "$NEMACS_EMACS" -Q --batch -L "$NEMACS_HOME/src" \
    -l nemacs-loadup -l "$NEMACS_HOME/scripts/nemacs-wrap-init.el" \
    --eval "(let ((dir (nemacs-resolve-user-emacs-directory)))
              (when (or (file-readable-p (concat dir \"early-init.el\"))
                        (file-readable-p (concat dir \"init.el\")))
                (nemacs-wrap-init (concat dir \"nemacs-init-wrapped\")
                                   (concat dir \"early-init.el\")
                                   (concat dir \"init.el\"))))" \
    >/dev/null 2>&1 || true
fi

# --- bootstrap form ------------------------------------------------

# Build the lisp form we hand to the driver.  The form sets the
# nemacs-main-options plist + load-path then requires nemacs-main +
# calls nemacs-main / nemacs-batch-main.

shell_quote() {
  # Emacs/nelisp string literal escaping for filenames + sexps.
  printf '%s' "$1" | perl -0777 -pe 's/\\/\\\\/g; s/"/\\"/g; s/\r/\\r/g; s/\n/\\n/g'
}

lisp_file_string() {
  # Escape a file as one Emacs/NeLisp string literal body.
  perl -0777 -pe 's/\\/\\\\/g; s/"/\\"/g; s/\r/\\r/g; s/\n/\\n/g' "$1"
}

one_line_form() {
  # The standalone reader REPL consumes one input form per line.
  printf '%s' "$1" | perl -0777 -pe 's/\r?\n/ /g'
}

resolve_repl_load_path() {
  case "$1" in
    /*)
      printf '%s\n' "$1"
      return
      ;;
    */*)
      printf '%s\n' "$PWD/$1"
      return
      ;;
  esac
  local dir
  for dir in "${LOAD_PATHS[@]+"${LOAD_PATHS[@]}"}" \
             "$NEMACS_HOME/src" \
             "$NEMACS_HOME/vendor/emacs-lisp" \
             "$NEMACS_HOME/vendor/emacs-lisp/emacs-lisp"; do
    if [[ -r "$dir/$1" ]]; then
      printf '%s\n' "$dir/$1"
      return
    fi
    if [[ -r "$dir/$1.el" ]]; then
      printf '%s\n' "$dir/$1.el"
      return
    fi
  done
  printf '%s\n' "$1"
}

LOAD_LIST=""
for f in "${LOAD_FILES[@]+"${LOAD_FILES[@]}"}"; do
  LOAD_LIST+=" \"$(shell_quote "$f")\""
done

LOAD_PATH_LIST=""
for f in "${LOAD_PATHS[@]+"${LOAD_PATHS[@]}"}"; do
  LOAD_PATH_LIST+=" \"$(shell_quote "$f")\""
done

IMAGE_LIST=""
for f in "${IMAGE_FILES[@]+"${IMAGE_FILES[@]}"}"; do
  IMAGE_LIST+=" \"$(shell_quote "$f")\""
done

EVAL_LIST=""
for f in "${EVAL_FORMS[@]+"${EVAL_FORMS[@]}"}"; do
  # Each --eval is itself elisp source.  Host Emacs can parse it inside
  # the boot form; standalone NeLisp does not require `read' at boot time
  # and evaluates string forms through `nelisp--eval-source-string'.
  if [[ "$NEMACS_DRIVER" == "nelisp" ]]; then
    EVAL_LIST+=" \"$(shell_quote "$f")\""
  else
    EVAL_LIST+=" (read \"$(shell_quote "$f")\")"
  fi
done

FUNCALL_LIST=""
for f in "${FUNCALLS[@]+"${FUNCALLS[@]}"}"; do
  FUNCALL_LIST+=" '$(shell_quote "$f")"
done

ARG_LIST=""
for f in "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}"; do
  ARG_LIST+=" \"$(shell_quote "$f")\""
done

if (( BATCH )); then
  ENTRY_CALL='(nemacs-batch-main)'
else
  ENTRY_CALL='(nemacs-main)'
fi

if [[ "$NEMACS_RUNTIME_IMAGE" == "auto" ]]; then
  if (( BATCH )); then
    NEMACS_RUNTIME_IMAGE="$NEMACS_BATCH_RUNTIME_IMAGE"
  else
    NEMACS_RUNTIME_IMAGE="$NEMACS_INTERACTIVE_RUNTIME_IMAGE"
  fi
  if [[ ! -r "$NEMACS_RUNTIME_IMAGE" ]]; then
    NEMACS_RUNTIME_IMAGE=""
  fi
fi

if [[ "$NEMACS_DRIVER" == "host" ]]; then
  BOOT_HOST_PRELOAD_FORM="$(cat <<EOF
  (require 'cl-lib)
  (require 'cl-generic)
EOF
)"
  BOOT_LOAD_PATH_FORM="$(cat <<EOF
  (setq load-path
        (append (list$LOAD_PATH_LIST
                      "$(shell_quote "$NEMACS_HOME/src")")
                (and (boundp 'load-path) load-path)
                (list "$(shell_quote "$NEMACS_HOME/vendor/emacs-lisp")"
                      "$(shell_quote "$NEMACS_HOME/vendor/emacs-lisp/emacs-lisp")")))
EOF
)"
else
  BOOT_HOST_PRELOAD_FORM=""
  BOOT_LOAD_PATH_FORM="$(cat <<EOF
  (setq load-path
        (append (list$LOAD_PATH_LIST
                      "$(shell_quote "$NEMACS_HOME/src")"
                      "$(shell_quote "$NEMACS_HOME/vendor/emacs-lisp")"
                      "$(shell_quote "$NEMACS_HOME/vendor/emacs-lisp/emacs-lisp")")
                (and (boundp 'load-path) load-path)))
EOF
)"
fi

BOOTSTRAP_BUNDLE_LOAD=""
if [[ "$NEMACS_DRIVER" == "nelisp" && -z "$NEMACS_RUNTIME_IMAGE" && -n "$NEMACS_BOOTSTRAP_BUNDLE" && -r "$NEMACS_BOOTSTRAP_BUNDLE" && ! -r "$NEMACS_BOOTSTRAP_REPL" ]]; then
  BOOTSTRAP_BUNDLE_LOAD="  (load \"$(shell_quote "$NEMACS_BOOTSTRAP_BUNDLE")\" nil 'no-message t t)"
fi

BOOT_NELISP_SOURCE_REFRESH=""
if [[ "$NEMACS_DRIVER" == "nelisp" ]]; then
  BOOT_NELISP_SOURCE_REFRESH="$(cat <<EOF
  (load "$(shell_quote "$NEMACS_HOME/src/emacs-fns.el")" nil 'no-message)
  (load "$(shell_quote "$NEMACS_HOME/src/nemacs-main.el")" nil 'no-message)
EOF
)"
fi

if [[ "$NEMACS_DRIVER" == "nelisp" ]]; then
  if (( BATCH )); then
    BOOT_ENTRY_FORM="$(cat <<'EOF'
  (when (fboundp 'install-sigint-handler) (install-sigint-handler))
  (unless nemacs-initialized (nemacs-main--apply-startup-gate) (nemacs-init t))
  (nemacs-main--apply-options)
  (unless (nemacs-main-option :no-banner)
    (when (fboundp 'message)
      (message "%s" (nemacs-main-status-banner))))
EOF
)"
  else
    BOOT_ENTRY_FORM="$(cat <<EOF
  (when (fboundp 'install-sigint-handler) (install-sigint-handler))
  (when (fboundp 'install-winsize-handler) (install-winsize-handler))
  (when (fboundp 'install-jobctrl-handlers) (install-jobctrl-handlers))
  (unless nemacs-initialized (nemacs-main--apply-startup-gate) (nemacs-init))
  (nemacs-main--apply-options)
  (setq nemacs-main--repl-tui-ok (nemacs-main--realise-tui))
  (if nemacs-main--repl-tui-ok
      (unwind-protect
          (progn
            (nemacs-main--enable-tty-raw-input)
            (nemacs-main--enter-fullscreen)
            (nemacs-main--initial-paint)
            (nemacs-main--event-loop))
        (nemacs-main--disable-tty-raw-input))
    (progn
      (when (fboundp 'message)
        (message "nemacs: TUI not available, running batch-style"))
      (nemacs-main--apply-options)))
EOF
)"
  fi
else
  BOOT_ENTRY_FORM="  $ENTRY_CALL"
fi

BOOT_FORM="$(cat <<EOF
(progn
  (setq native-comp-enable-subr-trampolines nil
        comp-enable-subr-trampolines nil)
  (unless (boundp 'load-path) (defvar load-path nil))
  (setq nelisp-emacs-vendor-root "$(shell_quote "$NEMACS_HOME/vendor")")
$BOOT_HOST_PRELOAD_FORM
$BOOT_LOAD_PATH_FORM
$BOOTSTRAP_BUNDLE_LOAD
$BOOT_NELISP_SOURCE_REFRESH
  (require 'nemacs-main)
  (setq nemacs-main-options
        (list :batch $([ "$BATCH" = "1" ] && echo t || echo nil)
              :no-banner $([ "$NO_BANNER" = "1" ] && echo t || echo nil)
              :driver '$NEMACS_DRIVER
              :init-file-user $([ "$NO_INIT" = "1" ] && echo nil || echo '""')
              :inhibit-startup-screen $([ "$NO_SPLASH" = "1" ] && echo t || echo nil)
              :images (list$IMAGE_LIST)
              :load-path (list$LOAD_PATH_LIST)
              :load (list$LOAD_LIST)
              :eval-forms (list$EVAL_LIST)
              :funcall (list$FUNCALL_LIST)
              :args (list$ARG_LIST)))
$BOOT_ENTRY_FORM)
EOF
)"

# --- driver dispatch -----------------------------------------------

case "$NEMACS_DRIVER" in
  host)
    if (( BATCH )); then
      exec "$NEMACS_EMACS" -Q --batch "${HOST_EARLY_ARGS[@]+"${HOST_EARLY_ARGS[@]}"}" --eval "$BOOT_FORM" "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}"
    else
      # Interactive: -Q keeps user init out of nemacs's way.
      exec "$NEMACS_EMACS" -Q "${HOST_EARLY_ARGS[@]+"${HOST_EARLY_ARGS[@]}"}" --eval "$BOOT_FORM" "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}"
    fi
    ;;
  nelisp)
    if [[ ! -x "$NEMACS_NELISP" ]]; then
      echo "nemacs: nelisp driver requested but $NEMACS_NELISP is not executable" >&2
      echo "  Set NEMACS_NELISP, export NELISP_HOME, or build it via: bin/build-nelisp" >&2
      echo "  Direct build: cd $NELISP_HOME && make standalone-reader" >&2
      exit 1
    fi
    if [[ -n "$NEMACS_RUNTIME_IMAGE" && ! -r "$NEMACS_RUNTIME_IMAGE" ]]; then
      echo "nemacs: runtime image is not readable: $NEMACS_RUNTIME_IMAGE" >&2
      exit 1
    fi
    ulimit -s "$NEMACS_NELISP_STACK" 2>/dev/null || true
    [[ "$NEMACS_NELISP_MEMORY" == "unlimited" ]] || ulimit -v "$NEMACS_NELISP_MEMORY" 2>/dev/null || true
    if [[ "$(nelisp_driver_kind)" == "standalone-reader" ]]; then
      if [[ -n "$NEMACS_RUNTIME_IMAGE" ]]; then
        exec "$NEMACS_NELISP" exec-runtime-image "$NEMACS_RUNTIME_IMAGE" "$BOOT_FORM"
      elif [[ -r "$NEMACS_BOOTSTRAP_REPL" ]]; then
        tmp="$(mktemp "${TMPDIR:-/tmp}/nemacs-repl-boot.XXXXXX.el")"
        : > "$tmp"
        if [[ -r "$NELISP_HOME/scripts/nelisp-stdlib-prelude.el" ]]; then
          printf '(nelisp--eval-source-string "%s")\n' \
            "$(lisp_file_string "$NELISP_HOME/scripts/nelisp-stdlib-prelude.el")" >> "$tmp"
        fi
        cat "$NEMACS_BOOTSTRAP_REPL" >> "$tmp"
        printf '%s\n' "(setq native-comp-enable-subr-trampolines nil comp-enable-subr-trampolines nil)" >> "$tmp"
        printf '%s\n' "(unless (boundp 'load-path) (defvar load-path nil))" >> "$tmp"
        printf '%s\n' "(setq nelisp-emacs-vendor-root \"$(shell_quote "$NEMACS_HOME/vendor")\")" >> "$tmp"
        printf '%s\n' "$(one_line_form "$BOOT_LOAD_PATH_FORM")" >> "$tmp"
        printf '%s\n' "(load \"$(shell_quote "$NEMACS_HOME/src/emacs-fns.el")\" nil 'no-message)" >> "$tmp"
        printf '%s\n' "(load \"$(shell_quote "$NEMACS_HOME/src/nemacs-main.el")\" nil 'no-message)" >> "$tmp"
        printf '%s\n' "(require 'nemacs-main)" >> "$tmp"
        REPL_OPTIONS_FORM="$(cat <<EOF
(setq nemacs-main-options
      (list :batch $([ "$BATCH" = "1" ] && echo t || echo nil)
            :no-banner $([ "$NO_BANNER" = "1" ] && echo t || echo nil)
            :driver '$NEMACS_DRIVER
            :init-file-user $([ "$NO_INIT" = "1" ] && echo nil || echo '""')
            :inhibit-startup-screen $([ "$NO_SPLASH" = "1" ] && echo t || echo nil)
            :images (list$IMAGE_LIST)
            :load-path (list$LOAD_PATH_LIST)
            :load (list$LOAD_LIST)
            :eval-forms (list$EVAL_LIST)
            :funcall (list$FUNCALL_LIST)
            :args (list$ARG_LIST)))
EOF
)"
        printf '%s\n' "$(one_line_form "$REPL_OPTIONS_FORM")" >> "$tmp"
        if (( BATCH )); then
          # The standalone-reader REPL can capture top-level option defvars as
          # nil when one closure calls another.  Keep batch CLI processing at
          # top level so -L/-l/--eval/-f see the plist installed above.
          printf '%s\n' "(when (fboundp 'install-sigint-handler) (install-sigint-handler))" >> "$tmp"
          printf '%s\n' "(unless nemacs-initialized (nemacs-main--apply-startup-gate) (nemacs-init t))" >> "$tmp"
          printf '%s\n' "(nemacs-main--apply-options)" >> "$tmp"
          printf '%s\n' "(unless (nemacs-main-option :no-banner) (when (fboundp 'message) (message \"%s\" (nemacs-main-status-banner))))" >> "$tmp"
        else
          printf '%s\n' "(when (fboundp 'install-sigint-handler) (install-sigint-handler))" >> "$tmp"
          printf '%s\n' "(when (fboundp 'install-winsize-handler) (install-winsize-handler))" >> "$tmp"
          printf '%s\n' "(when (fboundp 'install-jobctrl-handlers) (install-jobctrl-handlers))" >> "$tmp"
          printf '%s\n' "(unless nemacs-initialized (nemacs-main--apply-startup-gate) (nemacs-init))" >> "$tmp"
          printf '%s\n' "(nemacs-main--apply-options)" >> "$tmp"
          printf '%s\n' "(setq nemacs-main--repl-tui-ok (nemacs-main--realise-tui))" >> "$tmp"
          if (( ! NO_BANNER )); then
            printf '%s\n' "(when (and nemacs-main--repl-tui-ok (fboundp 'message)) (message \"%s\" (nemacs-main-status-banner)))" >> "$tmp"
          fi
          if [[ "$NEMACS_DRIVER" == "host" ]]; then
            printf '%s\n' "(if (and nemacs-main--repl-tui-ok (boundp 'noninteractive) (not noninteractive)) (nemacs-main--install-keymap-host) (when nemacs-main--repl-tui-ok (unwind-protect (progn (princ \"NEMACS_TUI_TAIL_REACHED\\n\") (nemacs-main--enable-tty-raw-input) (nemacs-main--enter-fullscreen) (nemacs-main--initial-paint) (nemacs-main--event-loop)) (nemacs-main--disable-tty-raw-input))))" >> "$tmp"
          else
            # Cheap unconditional diagnosability marker: emitted just before the
            # raw-input handoff so pty smoke probes can tell "boot form reached
            # the interactive tail" apart from "boot form never got this far"
            # even when the rest of the TUI never becomes observable. Batch mode
            # never reaches this branch, so the marker cannot leak into scripted
            # --batch output.
            printf '%s\n' "(if nemacs-main--repl-tui-ok (unwind-protect (progn (princ \"NEMACS_TUI_TAIL_REACHED\\n\") (nemacs-main--enable-tty-raw-input) (nemacs-main--enter-fullscreen) (nemacs-main--initial-paint) (nemacs-main--event-loop)) (nemacs-main--disable-tty-raw-input)) (progn (when (fboundp 'message) (message \"nemacs: TUI not available, running batch-style\")) (nemacs-main--apply-options)))" >> "$tmp"
          fi
        fi
        printf '%s\n' ",quit" >> "$tmp"
        restore_repl_tty() {
          if (( ! BATCH )); then
            stty sane < /dev/tty 2>/dev/null || true
          fi
        }
        if (( ! BATCH )); then
          trap 'restore_repl_tty; exit 143' TERM HUP
          trap 'restore_repl_tty; exit 130' INT
        fi
        set +e
        "$NEMACS_NELISP" --repl --no-prompt --no-print < "$tmp"
        rc=$?
        set -e
        restore_repl_tty
        if (( ! BATCH )); then
          trap - TERM HUP INT
        fi
        rm -f "$tmp"
        exit "$rc"
      else
        tmp="$(mktemp "${TMPDIR:-/tmp}/nemacs-boot.XXXXXX.el")"
        printf '%s\n0\n' "$BOOT_FORM" > "$tmp"
        set +e
        "$NEMACS_NELISP" --load "$tmp"
        rc=$?
        set -e
        rm -f "$tmp"
        exit "$rc"
      fi
    elif [[ -n "$NEMACS_RUNTIME_IMAGE" ]]; then
      exec "$NEMACS_NELISP" exec-runtime-image "$NEMACS_RUNTIME_IMAGE" "$BOOT_FORM"
    else
      exec "$NEMACS_NELISP" --eval "$BOOT_FORM"
    fi
    ;;
  *)
    echo "nemacs: unknown --driver=$NEMACS_DRIVER (expected host or nelisp)" >&2
    exit 2
    ;;
esac
