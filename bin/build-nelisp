#!/usr/bin/env bash
# bin/build-nelisp - fetch + build NeLisp in vendor/nelisp/
#
# Layer-2 self-containment: nemacs depends on a NeLisp executable when
# the experimental `--driver=nelisp' path is used.  Current NeLisp
# builds target/nelisp via a pure-Elisp AOT path.
#
# Default behaviour: clone the upstream nelisp repo into
# vendor/nelisp/ (gitignored) and run `make standalone-reader'.
# The resulting binary is at vendor/nelisp/target/nelisp.  Older
# checkouts may still produce target/nelisp-standalone-reader; this
# script accepts that path as a compatibility fallback.
#
# Idempotent: re-running `bin/build-nelisp` is a no-op when the
# vendored checkout exists and is up to date.  Pass `--rebuild` to
# force a fresh build.
#
# Environment overrides:
#   NELISP_VENDOR_DIR vendored checkout path (default: vendor/nelisp)
#   NELISP_REPO_URL   git remote (default: https://github.com/zawatton/nelisp.git)
#   NELISP_REPO_REF   branch / tag / SHA (default: main)
#   MAKE              make binary (default: make)
#   EMACS             emacs binary passed to NeLisp make (default: emacs)

set -euo pipefail

SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)"
NEMACS_HOME="$(cd "$SCRIPT_PATH/.." && pwd)"
VENDOR_DIR="${NELISP_VENDOR_DIR:-$NEMACS_HOME/vendor/nelisp}"
NELISP_REPO_URL="${NELISP_REPO_URL:-https://github.com/zawatton/nelisp.git}"
NELISP_REPO_REF="${NELISP_REPO_REF:-main}"
MAKE="${MAKE:-make}"
EMACS="${EMACS:-emacs}"

REBUILD=0
PULL=1
for arg in "$@"; do
  case "$arg" in
    --rebuild) REBUILD=1 ;;
    --no-pull) PULL=0 ;;
    --help|-h)
      sed -n '2,25p' "$0"
      exit 0
      ;;
    *) echo "build-nelisp: unknown arg: $arg" >&2; exit 2 ;;
  esac
done

echo "build-nelisp: vendor dir = $VENDOR_DIR"
echo "build-nelisp: ref        = $NELISP_REPO_REF"

if [[ ! -d "$VENDOR_DIR/.git" ]]; then
  echo "build-nelisp: cloning $NELISP_REPO_URL → $VENDOR_DIR"
  mkdir -p "$VENDOR_DIR"
  git clone "$NELISP_REPO_URL" "$VENDOR_DIR"
  ( cd "$VENDOR_DIR" && git checkout "$NELISP_REPO_REF" )
elif (( PULL )); then
  echo "build-nelisp: pulling latest"
  ( cd "$VENDOR_DIR" \
      && git fetch origin "$NELISP_REPO_REF" \
      && git checkout "$NELISP_REPO_REF" \
      && git pull origin "$NELISP_REPO_REF" )
fi

if (( REBUILD )); then
  ( cd "$VENDOR_DIR" && rm -f target/nelisp target/nelisp-standalone-reader && rm -rf target/standalone-units )
fi

echo "build-nelisp: make standalone-reader"
( cd "$VENDOR_DIR" && EMACS="$EMACS" "$MAKE" standalone-reader )

BIN="$VENDOR_DIR/target/nelisp"
if [[ ! -x "$BIN" && -x "$VENDOR_DIR/target/nelisp-standalone-reader" ]]; then
  BIN="$VENDOR_DIR/target/nelisp-standalone-reader"
fi
if [[ ! -x "$BIN" ]]; then
  echo "build-nelisp: build succeeded but $BIN is missing — fatal" >&2
  exit 1
fi

echo "build-nelisp: OK — binary at $BIN"
tmp="$(mktemp "${TMPDIR:-/tmp}/nelisp-standalone-reader-smoke.XXXXXX.el")"
printf '%s\n' '(+ 40 2)' > "$tmp"
set +e
out="$("$BIN" --load "$tmp")"
rc=$?
set -e
rm -f "$tmp"
if [[ "$out" != 42 && "$rc" != 42 ]]; then
  echo "build-nelisp: standalone reader smoke failed: output=$out exit=$rc expected=42" >&2
  exit 1
fi
echo "build-nelisp: standalone reader smoke OK (output=$out exit=$rc)"
