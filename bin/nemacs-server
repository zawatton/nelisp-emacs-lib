#!/bin/bash
# nemacs-server — serve real emacsclient -e round-trips from the
# standalone NeLisp reader (M14 server/emacsclient lane).
#
# Usage: nemacs-server [NAME] [SOCKET_DIR]
#   NAME        server name (default: nemacs)
#   SOCKET_DIR  socket directory (default: /tmp/nemacs-server)
# Env:
#   NELISP      reader binary (default: vendor/nelisp/target/nelisp)
#
# Connect with:  emacsclient -s SOCKET_DIR/NAME -e '(+ 1 2)'
set -euo pipefail
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
NAME=${1:-nemacs}
SOCK_DIR=${2:-/tmp/nemacs-server}
NELISP=${NELISP:-$ROOT/vendor/nelisp/target/nelisp}
[ -x "$NELISP" ] || { echo "nemacs-server: reader not executable: $NELISP" >&2; exit 1; }

# The reader's getenv is a stub; configuration travels in a generated
# preamble (same pattern as the anvil-runtime daemon launcher).
# M18 SIGSEGV root-cause (2026-06-11, deterministic 4/4 vs 4/4 A/B):
# when server-ensure-safe-dir's mkdir BRANCH runs on the reader with
# the package heap loaded, the first client request later segfaults;
# with the socket dir pre-created (attrs branch) the same server is
# stable.  Pre-create the dir here — the make-directory polyfill path
# stays quarantined as a recorded reader finding.
mkdir -p "$SOCK_DIR"
chmod 700 "$SOCK_DIR"

# Loader reconcile Phase 3: wrapped-init directory unification.  Default to
# `/tmp' (unchanged) so the existing convention of the GUI launcher
# (gui/bin/nemacs, NEMACS_TRANSPORT_DIR default /tmp) already having written
# nemacs-init-wrapped(+companions) there keeps working with zero behavior
# change.  A caller may instead point `NEMACS_USER_EMACS_DIRECTORY' at a
# directory of its own early-init.el/init.el; when host Emacs is available
# this server then wraps it itself ahead of time (same generator the GUI
# launcher and `bin/nemacs' use) -- opt-in, not run against the default /tmp
# case, so this stays exactly as safe/fast as before for existing callers.
NEMACS_EMACS=${NEMACS_EMACS:-emacs}
NEMACS_USER_EMACS_DIRECTORY=${NEMACS_USER_EMACS_DIRECTORY:-/tmp}
export NEMACS_USER_EMACS_DIRECTORY
NEMACS_SERVER_WRAP_DIR=${NEMACS_USER_EMACS_DIRECTORY%/}
NEMACS_SERVER_WRAPPER="$NEMACS_SERVER_WRAP_DIR/nemacs-init-wrapped"
if [ "$NEMACS_SERVER_WRAP_DIR" != "/tmp" ] \
   && [ ! -e "$NEMACS_SERVER_WRAPPER" ] \
   && { [ -f "$NEMACS_SERVER_WRAP_DIR/early-init.el" ] || [ -f "$NEMACS_SERVER_WRAP_DIR/init.el" ]; } \
   && command -v "$NEMACS_EMACS" >/dev/null 2>&1; then
  "$NEMACS_EMACS" -Q --batch \
    -l "$ROOT/scripts/nemacs-wrap-init.el" \
    --eval "(nemacs-wrap-init \"$NEMACS_SERVER_WRAPPER\" \"$NEMACS_SERVER_WRAP_DIR/early-init.el\" \"$NEMACS_SERVER_WRAP_DIR/init.el\")" \
    >/dev/null 2>&1 || true
fi

PRE=$(mktemp /tmp/nemacs-server-preamble.XXXXXX.el)
trap 'rm -f "$PRE"' EXIT
# The whole driver is generated FLAT so every load runs at nesting
# depth 2 — the reader still mis-handles big package files at deeper
# nesting (M18 finding; the nested-load cap-restore fix in
# nelisp-standalone-build.el is necessary but not sufficient).
cat >"$PRE" <<EOF
(load "$ROOT/src/emacs-stub.el" nil t)
(load "$ROOT/src/emacs-stub-bulk.el" nil t)
(load "$ROOT/src/emacs-network-syscall-shim.el" nil t)
(load "$ROOT/src/emacs-network-ffi.el" nil t)
(load "$ROOT/src/emacs-process-events.el" nil t)
(load "$ROOT/src/emacs-eventloop.el" nil t)
(load "$ROOT/src/emacs-server-polyfills.el" nil t)
(load "$ROOT/src/emacs-server-client-polyfills.el" nil t)
(load "$ROOT/vendor/emacs-lisp/server.el" nil t)
(emacs-server-client-polyfills-install)
(setq server-name "$NAME")
(setq server-use-tcp nil)
(setq server-socket-dir "$SOCK_DIR")
;; L5: bring up the full nemacs runtime (buffer/editor core, real
;; find-file / save-buffer) on top of the M14 server/emacsclient
;; polyfills already loaded above.  Same load-path / vendor-root
;; shape as bin/nemacs's nelisp-driver boot (bin/nemacs:443-462,579).
;; Flat top-level forms only (M18 nesting-depth-2 discipline, see the
;; header note above).  Loading nemacs-main.el pulls in
;; emacs-fileio-builtins, whose standalone-overrides force-reinstall
;; the real find-file/save-buffer over the M14 stubs.
(unless (boundp 'load-path) (defvar load-path nil))
(setq nelisp-emacs-vendor-root "$ROOT/vendor")
(setq load-path
      (append (list "$ROOT/src"
                    "$ROOT/vendor/emacs-lisp"
                    "$ROOT/vendor/emacs-lisp/emacs-lisp")
              (and (boundp 'load-path) load-path)))
(load "$ROOT/src/emacs-fns.el" nil t)
;; save-buffer / write-file (installed below by nemacs-main.el's
;; emacs-fileio-builtins chain) declare themselves with (interactive
;; ...).  That form is only a no-op polyfill under src/emacs-eval.el
;; (real Emacs has a native Finteractive primitive; the standalone
;; reader does not), and emacs-eval.el is not on nemacs-loadup's
;; require graph.  Load it here, flat top-level, so interactive is
;; bound before any client calls a command that declares it -- doing
;; this load lazily from inside a request handler instead hits the
;; same nested-load risk class as the M18 finding above.
(load "$ROOT/src/emacs-eval.el" nil t)
(load "$ROOT/src/nemacs-main.el" nil t)
;; Loader reconcile Phase 3: nemacs-init (via nemacs-load-user-init-files,
;; src/nemacs-loadup.el) already consumes any wrapped-init transport at
;; NEMACS_USER_EMACS_DIRECTORY/nemacs-init-wrapped through the shared
;; nemacs-init-transport-consume helper (src/nemacs-init-transport.el, the
;; same one the GUI bridge uses) -- no separate hand-rolled marker/load
;; dance is needed here any more.
(nemacs-init t)
(nelisp--write-stderr-line
 (concat "nemacs-server: user init applied forms="
         (number-to-string (if (boundp 'nemacs-init--applied)
                                nemacs-init--applied
                              0))))
EOF
cat >>"$PRE" <<EOF
(nemacs-server-start)
(nelisp--write-stderr-line
 (concat "nemacs-server: listening on " (server--file-name)))
(let ((alive t))
  (while alive
    (accept-process-output nil 0 200)))
EOF
# large pure-elisp loads (user packages) need the same stack headroom
# the Makefile bake targets use
# M18 finding: ulimit -s unlimited moves the address-space layout and collides
# with the reader fixed control region (deterministic SIGSEGV on the first
# request once the package heap is loaded) - default stack is the safe choice.
exec "$NELISP" --eval "(load \"$PRE\" nil t)"
